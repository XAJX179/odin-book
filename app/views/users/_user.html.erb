<li>
  <div
    id="<%= controller.action_name == "search" ? dom_id(user,:search_result) : dom_id(user) %>"
  >
    <%= link_to user_profile_path(user), data: { turbo_frame: "_top" } do %>
      <div>
        <% if user.profile.avatar.attached? %>
          <%= image_tag user.profile.avatar.variant(resize_to_limit: [100, 100]) %>
        <% end %>
        <h2>
          name :
          <%= user.profile.display_name %>
        </h2>
        <h3>
          username : @<%= user.name %>
        </h3>
        <p>
          about :
          <%= user.profile.about %>
        </p>
      </div>
    <% end %>

    <% if controller.action_name == "search" %>
      <%= turbo_frame_tag "search_result_user_#{user.id}_profile_action_button",
      src: buttons_of_user_profile_path(user) %>
    <% else %>
      <%= turbo_frame_tag "user_#{user.id}_profile_action_button",
      src: buttons_of_user_profile_path(user) %>
    <% end %>
  </div>
</li>
