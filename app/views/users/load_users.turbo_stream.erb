<%= turbo_stream.append "users" do %>
  <% @users.each do |user| %>
    <%= render user %>
  <% end %>
<% end %>

<%= turbo_stream.replace "users-loader" do %>
  <% shift = Post::LIMIT %>
  <%= turbo_frame_tag "users-loader",
  loading: "lazy",
  src: load_users_url(offset: @offset.to_i + shift, format: "turbo_stream") do %>
    <p>
      Loading more...
    </p>
  <% end %>
<% end %>
