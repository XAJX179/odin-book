streams: users
<%= "users_viewer_#{current_user.id}" %>

<%= tag.div data: {
              controller: "search",
              search_url_value: search_users_url,
              }  do %>

  <%= text_field_tag :name,
  "",
  placeholder: "Search users by name",
  data: {
    action: "keyup->search#fetchResults",
    search_target: "searchField",
  },
  autofocus: true,
  autocomplete: "off" %>
  <div data-search-target="results"></div>
<% end %>

<%= turbo_stream_from "users" %>
<%= turbo_stream_from "users_viewer_#{current_user.id}" %>

<%= tag.ul id: "users" %>

<%= turbo_frame_tag "users-loader",
loading: "lazy",
src: load_all_users_path(format: "turbo_stream") do %>
  <p>
    Loading...
  </p>
<% end %>
