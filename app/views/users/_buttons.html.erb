<% if current_user.id != user.id %>
  <% if  current_user.friend_ids.include?(user.id) %>
    <%= render partial: "friends/remove_button", locals: { user: user } %>
  <% elsif requests.empty? || requests.first.to_id == current_user.id || requests.second&.from_id == current_user.id %>
    <%= render partial: "friend_requests/send_button", locals: { user: user } %>
  <% else %>
    <%= render partial: "friend_requests/cancel_button",
    locals: {
      friend_request: requests.first,
    } %>
  <% end %>
<% else %>
  <%= turbo_frame_tag "user_#{user.id}_profile_action_button" %>
<% end %>
