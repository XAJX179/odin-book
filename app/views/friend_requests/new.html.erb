<h1>FriendRequests#new</h1>
<p>Find me in app/views/friend_requests/new.html.erb</p>
<%= form_with model: @friend_request do |f| %>

  <div class="form-errors">
    <% if !@friend_request.errors.empty? %>
      <%= @friend_request.errors.full_messages %>
    <% end %>
  </div>

  <div>
    <%= f.label :to, "Username : " %>
    <%= f.text_field :to %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
