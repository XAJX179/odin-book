<% if turbo_frame_request_id&.first(13) == "search_result" || defined? search_result %>
  <% id = "search_result_user_#{user.id}_profile_action_button" %>
<% else %>
  <% id = "user_#{user.id}_profile_action_button" %>
<% end %>
<%= turbo_frame_tag id do %>
  <%= button_to "Send friend request",
  friend_requests_path(friend_request: { to: user.name }) %>
<% end %>
