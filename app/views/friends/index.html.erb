<h1>Friends#index</h1>
<p>Find me in app/views/friends/index.html.erb</p>

<div>
  <%= @user.name %>
  id:
  <%= @user.id %>
  friends
</div>

<%= turbo_stream_from "friends-#{@user.id}" %>

<%= tag.div id: "friends" do %>
  <%= turbo_frame_tag "friends-loader",
    loading: "lazy", src: load_friends_for_user_url(id: @user.id,format: "turbo_stream") do %>
  <% end %>
<% end %>
