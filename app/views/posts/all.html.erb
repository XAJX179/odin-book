<h1>Posts#all</h1>
<p>Find me in app/views/posts/all.html.erb</p>

<%= turbo_frame_tag "posts" do %>
  <%= turbo_frame_tag "posts-loader",loading: "lazy",
                                    src: load_all_posts_url(format: "turbo_stream") do %>
    <%= render "shared/posts/loader" %>
  <% end %>
<% end %>
