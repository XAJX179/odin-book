<%= link_to "New Post", new_post_path, data: { turbo_frame: "_top" } %>

<%= tag.div data: {
              controller: "search",
              search_url_value: search_posts_url,
              }  do %>

  <%= text_field_tag :title,
  "",
  placeholder: "Search posts by title",
  data: {
    action: "keyup->search#fetchResults",
    search_target: "searchField",
  },
  autofocus: true,
  autocomplete: "off" %>
  <div data-search-target="results"></div>
<% end %>

<%= link_to "All", all_posts_path, data: { turbo_frame: "posts" } %>
<%= link_to "Feed", feed_posts_path, data: { turbo_frame: "posts" } %>

<%= turbo_frame_tag "posts", src: all_posts_path do %>
  <%= render "shared/posts/loader" %>
<% end %>
