<%= turbo_stream.before "posts-loader" do %>
  <% @posts.each do |post| %>
    <%= render post %>
  <% end %>
<% end %>

<%= turbo_stream.replace "posts-loader" do %>
  <% shift = Post::LIMIT %>
  <%= turbo_frame_tag "posts-loader",
  loading: "lazy",
  src: load_feed_posts_path(offset: @offset.to_i + shift, format: "turbo_stream") do %>
    <%= render "shared/posts/loader" %>
  <% end %>
<% end %>
