<h1>Posts#feed</h1>
<p>Find me in app/views/posts/feed.html.erb</p>

<%= turbo_frame_tag "posts" do %>
  <%= turbo_stream_from "feed-posts-for-#{current_user.id}" %>
  <%= turbo_frame_tag "posts-loader",loading: "lazy",
                                    src: load_feed_posts_path(format: "turbo_stream") do %>
    <%= render "shared/posts/loader" %>
  <% end %>
<% end %>
